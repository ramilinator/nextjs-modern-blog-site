        "code": "@import \"tailwindcss\";\n\n:root {\n  --background: #ffffff;\n  --foreground: #171717;\n}\n\n\n@theme inline {\n  --color-background: var(--background);\n  --color-foreground: var(--foreground);\n  --font-sans: var(--font-geist-sans);\n  --font-mono: var(--font-geist-mono);\n}\n\n@media (prefers-color-scheme: dark) {\n  :root {\n    --background: #0a0a0a;\n    --foreground: #ededed;\n  }\n}\n\n* {\n  transition:\n    background-color .3s,\n    color .3s,\n    border-color .3s;\n}\n\n.dark {\n  --color-background: #0f172a;\n  --color-foreground: #f8fafc;\n}\n\nbody {\n  background-color: var(--color-background);\n  color: var(--color-foreground);\n  transition: background-color 0.3s ease;\n}\n\n.blog-content {\n  @apply text-base leading-8;\n}\n\n.blog-content h1 {\n  @apply text-5xl font-bold mt-12 mb-6;\n}\n\n.blog-content h2 {\n  @apply text-4xl font-bold mt-10 mb-5;\n}\n\n.blog-content h3 {\n  @apply text-3xl font-semibold mt-8 mb-4;\n}\n\n.blog-content h4 {\n  @apply text-2xl font-semibold mt-6 mb-3;\n}\n\n.blog-content p {\n  @apply mb-6 leading-8;\n}\n\n.blog-content a {\n  @apply text-blue-600 underline hover:text-blue-700;\n}\n\n.blog-content ul {\n  @apply list-disc pl-6 mb-6;\n}\n\n.blog-content ol {\n  @apply list-decimal pl-6 mb-6;\n}\n\n.blog-content li {\n  @apply mb-2;\n}\n\n.blog-content blockquote {\n  @apply border-l-4 border-gray-300 pl-4 italic my-8;\n}\n\n.blog-content hr {\n  @apply my-10;\n}\n\n.blog-content img {\n  @apply rounded-xl my-8 mx-auto;\n}\n\n.blog-content strong {\n  @apply font-semibold;\n}\n\n.blog-content em {\n  @apply italic;\n}\n\n.blog-content pre {\n  @apply bg-gray-900 text-white rounded-xl overflow-x-auto;\n}\n\n.blog-content code {\n  @apply px-1 py-0.5 rounded text-sm;\n}\n\n.blog-content table {\n  @apply w-full border-collapse my-8;\n}\n\n.blog-content th {\n  @apply border p-3 font-semibold text-left;\n}\n\n.blog-content td {\n  @apply border p-3;\n}\n\n.shiki {\n  border-radius: 0.75rem;\n  overflow-x: auto;\n}\n\n.shiki code {\n  font-size: 0.9rem;\n}\n\npre {\n  margin: 0;\n  padding: 1.5rem;\n  overflow-x: auto;\n  background: transparent !important;\n}\n\npre code {\n  font-size: 14px;\n  line-height: 1.8;\n  font-family: \"JetBrains Mono\", monospace;\n}\n\ncode {\n  font-family: \"JetBrains Mono\", monospace;\n}",
